# osint-engine/.env
# LLM API Keys（至少配置一个）
MIMO_API_KEY=your_mimo_api_key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# 可选：DeepSeek / Anthropic（MIMO 未配置时回退）
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Search API（可选，不配置则使用 DuckDuckGo 免费搜索）
SERPAPI_API_KEY=

# Database
DATABASE_URL=sqlite:///data/osint.db

# Server
BACKEND_PORT=8000
FRONTEND_PORT=3000
